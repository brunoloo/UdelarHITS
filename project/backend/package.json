{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "db:drop": "psql -h localhost -p 5432 -U brunoloo -d postgres -c \"DROP DATABASE IF EXISTS udelarhits;\"",
    "db:create": "psql -h localhost -p 5432 -U brunoloo -d postgres -c \"CREATE DATABASE udelarhits OWNER brunoloo;\"",
    "db:schema": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/schema.sql",
    "db:reset": "npm run db:drop && npm run db:create && npm run db:schema",
    "db:migrate:fase8": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase8_solicitud_seguimiento.sql",
    "db:migrate:fase9": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase9_categoria_icono.sql",
    "db:migrate:fase10": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase10_me_gusta_privado.sql",
    "db:migrate:fase11": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase11_verificacion_registro.sql",
    "db:migrate:fase12": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase12_guardados.sql",
    "db:migrate:fase13": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase13_fijados.sql",
    "db:migrate:fase14": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase14_suscripcion_categoria.sql",
    "db:migrate:fase15": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase15_adjuntos.sql",
    "db:migrate:fase16": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_fase16_encuestas.sql",
    "db:migrate:chat": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_chat.sql",
    "db:migrate:chat-delete": "psql -h localhost -p 5432 -U brunoloo -d udelarhits -f ../database/migrations/migration_chat_delete.sql",
    "db:test:drop": "psql -h localhost -p 5432 -U brunoloo -d postgres -c \"DROP DATABASE IF EXISTS udelarhits_test;\"",
    "db:test:create": "psql -h localhost -p 5432 -U brunoloo -d postgres -c \"CREATE DATABASE udelarhits_test OWNER brunoloo;\"",
    "db:test:schema": "psql -h localhost -p 5432 -U brunoloo -d udelarhits_test -f ../database/schema.sql",
    "db:test:reset": "npm run db:test:drop && npm run db:test:create && npm run db:test:schema",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:chat": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --runInBand tests/chat/chat.test.js",
    "seed:admin": "node src/seeds/seedAdmin.js",
    "seed:test": "node src/seeds/seedTestData.js",
    "seed:testV2": "node src/seeds/seedTestDataV2.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cookie": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "file-type": "^22.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "resend": "^6.12.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
