#Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udelarhits
DB_USER=your_user
DB_PASSWORD=your_password

#PORT
PORT=5001

#CORS - Orígenes permitidos separados por coma (sin espacios)
URL=http://localhost:3000,http://localhost:5001

#NODE
NODE_ENV=development

#CLOUDINARY
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

#JWT token (generar con: openssl rand -hex 32)
JWT_SECRET=reemplaza_por_un_secreto_largo_aleatorio
JWT_EXPIRES_IN=7d