#Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=udelarhits
DB_USER=your_user
DB_PASSWORD=your_password

#PORT
PORT=5001

#CORS - Orígenes permitidos separados por coma (sin espacios)
URL=http://localhost:3000,http://localhost:5001

#NODE
NODE_ENV=development

#CLOUDINARY
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

#JWT token (generar con: openssl rand -hex 32)
JWT_SECRET=reemplaza_por_un_secreto_largo_aleatorio
JWT_EXPIRES_IN=7d


#RESEND
RESEND_API_KEY=re_api_key
RESEND_FROM=UdelarHITS <cuenta@udelarhits.com>
APP_URL=http://localhost:5001

#GOOGLE OAUTH
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

#TRENDING
UMBRAL_FACTOR_PARTICIPANTES=0.34
UMBRAL_MIN_PARTICIPANTES=3
UMBRAL_MAX_PARTICIPANTES=15
UMBRAL_VISITANTE_MIN=10
UMBRAL_VISITANTE_MULT=2
TRENDING_HALF_LIFE_HOURS=48

#DEFENSAS DE INFRAESTRUCTURA (modos de ahorro)
# Defensa 1: máximo de conversaciones de chat activas simultáneas. Al llegar al
# máximo se rechaza ABRIR conversaciones nuevas (las existentes siguen).
CHAT_MAX_ACTIVE_CONVERSATIONS=350
# Una conversación sin actividad por este tiempo libera su lugar (ms).
CHAT_ACTIVE_TTL_MS=600000
# Defensa 2: histéresis de notificaciones en tiempo real. Por encima del umbral
# de pausa se apaga el push (las notificaciones se siguen guardando); recién por
# debajo del umbral de reanudación se vuelve a prender.
NOTIF_RT_PAUSE_THRESHOLD=1000
NOTIF_RT_RESUME_THRESHOLD=800
# Defensa 3: retención de mensajes de chat (días). Los más viejos se borran en
# una pasada diaria automática.
CHAT_RETENTION_DAYS=30
# Defensa 5: ventana del límite "1 recuperación de contraseña por cuenta" (ms).
# Default 24hs; configurable solo para poder testearlo.
FORGOT_PASSWORD_ACCOUNT_WINDOW_MS=86400000